{
  "schema_version": 1,
  "piloth_version": "1.11.0",
  "coverage": "partial",
  "note": "SSOT khai bao authority cua tung capability (skill/rule/gate/adapter/guard-mode). Fail-closed: field authority thieu = quyen rong nhat. Coverage=partial: danh muc duoc bo sung tang dan qua van hanh that (va Forge/T3 se giup giu day du). Khong duplicate SSOT khac; day la noi khai authority, khong phai noi dinh nghia capability.",
  "authority_defaults": {
    "paths": [],
    "guard_modes": [],
    "entitlements": [],
    "enforcement_surface": [],
    "writes_policy": false
  },
  "capabilities": [
    {
      "id": "os-start",
      "kind": "guard-mode",
      "layer": "Runtime",
      "description": "Mo task run, ghi contract + target snapshot, chon mode, tinh required gates.",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**"],
        "guard_modes": ["os-start"],
        "writes_policy": false
      }
    },
    {
      "id": "os-close",
      "kind": "guard-mode",
      "layer": "Runtime",
      "description": "Validate receipt vs gates/evidence/footprint/truth-in-seal, seal, dong run.",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**", "pilothOS/memory/state/receipt-seals.jsonl"],
        "guard_modes": ["os-close"],
        "enforcement_surface": ["scope", "correctness", "disclosure", "traceability", "architecture", "reuse_non_duplication", "regression", "human_review", "prototype", "ui_quality", "design_system", "design_token_coverage", "operational_approval"],
        "writes_policy": false
      }
    },
    {
      "id": "contract-write",
      "kind": "guard-mode",
      "layer": "Runtime",
      "description": "Ghi task contract truoc khi sua file (contract-before-edit gate).",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**"],
        "guard_modes": ["contract-write"],
        "enforcement_surface": ["scope"],
        "writes_policy": false
      }
    },
    {
      "id": "tool-check",
      "kind": "guard-mode",
      "layer": "Tools",
      "description": "Kiem tra risk/timeout/approval + entitlement cua tool command vs contract.",
      "authority": {
        "guard_modes": ["tool-check"],
        "entitlements": [],
        "enforcement_surface": ["correctness"],
        "writes_policy": false
      }
    },
    {
      "id": "receipt-seal",
      "kind": "guard-mode",
      "layer": "Runtime",
      "description": "Emit hash seal (SHA-256) over receipt/contract/diff/changed files; --record append ledger.",
      "authority": {
        "paths": ["pilothOS/memory/state/receipt-seals.jsonl"],
        "guard_modes": ["receipt-seal"],
        "writes_policy": false
      }
    },
    {
      "id": "capability-check",
      "kind": "guard-mode",
      "layer": "Governance",
      "description": "Validate capability-manifest.json (shape + fail-closed defaults). Nen tang cua authority model.",
      "authority": {
        "paths": ["pilothOS/governance/capability-manifest.json"],
        "guard_modes": ["capability-check", "capability-list", "authority-delta"],
        "writes_policy": false
      }
    },
    {
      "id": "review-request",
      "kind": "guard-mode",
      "layer": "Runtime",
      "description": "Mo human-review round-trip backing gate human_review.",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**"],
        "guard_modes": ["review-request", "review-feedback", "review-verify"],
        "enforcement_surface": ["human_review"],
        "writes_policy": false
      }
    },
    {
      "id": "human_review",
      "kind": "gate",
      "layer": "Evaluation",
      "description": "Human approved; blockers/majors resolved. Backed by review round-trip artifacts.",
      "authority": {
        "enforcement_surface": ["human_review"],
        "writes_policy": false
      }
    },
    {
      "id": "prototype",
      "kind": "gate",
      "layer": "Evaluation",
      "description": "≥2 UI options, valid method, chosen ∈ options.",
      "authority": {
        "enforcement_surface": ["prototype"],
        "writes_policy": false
      }
    },
    {
      "id": "ui_quality",
      "kind": "gate",
      "layer": "Evaluation",
      "description": "Browser/visual evidence bat defect nguoi dung thay duoc.",
      "authority": {
        "entitlements": ["tool.browser"],
        "enforcement_surface": ["ui_quality"],
        "writes_policy": false
      }
    },
    {
      "id": "reuse_non_duplication",
      "kind": "gate",
      "layer": "Evaluation",
      "description": "Da kiem code hien co, reuse DS/tools, khong duplicate.",
      "authority": {
        "enforcement_surface": ["reuse_non_duplication"],
        "writes_policy": false
      }
    },
    {
      "id": "piloth-prototype",
      "kind": "skill",
      "layer": "Skills",
      "description": "Designer sinh ≥2 UI options truoc code; pick qua human_review round-trip.",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**/artifacts/**"],
        "guard_modes": ["os-evidence", "review-request", "review-feedback", "review-verify"],
        "entitlements": ["tool.browser"],
        "enforcement_surface": ["prototype", "human_review"],
        "writes_policy": false
      }
    },
    {
      "id": "piloth-discovery",
      "kind": "skill",
      "layer": "Skills",
      "description": "Front-of-phase questionnaire; decisions fold vao contract discovery_decisions.",
      "authority": {
        "paths": ["pilothOS/memory/state/os-runs/**/artifacts/**"],
        "guard_modes": ["os-evidence", "review-request", "review-feedback", "review-verify"],
        "writes_policy": false
      }
    },
    {
      "id": "pilothos-init",
      "kind": "skill",
      "layer": "Skills",
      "description": "Install engine flow (preflight->detect->audit->plan->apply->verify) qua installer.",
      "authority": {
        "paths": ["**"],
        "guard_modes": ["preflight", "detect", "audit-assets", "registry-assets", "self-check"],
        "writes_policy": true
      }
    },
    {
      "id": "coding-behavior",
      "kind": "rule",
      "layer": "Rules",
      "description": "Discipline khi code: don gian, surgical, evidence.",
      "authority": {
        "enforcement_surface": ["scope", "architecture"],
        "writes_policy": true
      }
    },
    {
      "id": "evidence",
      "kind": "rule",
      "layer": "Rules",
      "description": "Quy tac ket luan dua tren Evidence.",
      "authority": {
        "enforcement_surface": ["correctness", "disclosure"],
        "writes_policy": true
      }
    },
    {
      "id": "layer-boundary",
      "kind": "rule",
      "layer": "Rules",
      "description": "Dat dung responsibility/layer.",
      "authority": {
        "enforcement_surface": ["architecture"],
        "writes_policy": true
      }
    },
    {
      "id": "adapter-claude",
      "kind": "adapter",
      "layer": "Adapters",
      "description": "Claude Code adapter (base, khong go duoc): hooks, commands, settings.",
      "authority": {
        "paths": [".claude/**"],
        "writes_policy": false
      }
    },
    {
      "id": "adapter-codex",
      "kind": "adapter",
      "layer": "Adapters",
      "description": "Codex adapter (thin bridge tro ve pilothOS/).",
      "authority": {
        "paths": [".codex/**"],
        "writes_policy": false
      }
    },
    {
      "id": "adapter-cursor",
      "kind": "adapter",
      "layer": "Adapters",
      "description": "Cursor adapter (thin bridge tro ve pilothOS/).",
      "authority": {
        "paths": [".cursor/**"],
        "writes_policy": false
      }
    },
    {
      "id": "adapter-antigravity",
      "kind": "adapter",
      "layer": "Adapters",
      "description": "Antigravity adapter (thin bridge tro ve pilothOS/).",
      "authority": {
        "paths": [".antigravity/**"],
        "writes_policy": false
      }
    }
  ]
}
