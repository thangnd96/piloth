{
  "permissions": {
    "allow": [
      "Bash(python3 pilothOS/scripts/pilothos_guard.py:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(*secret*)"
    ]
  },
  "env": {
    "PILOTHOS_VERSION": "1.12.0"
  },
  "statusLine": {
    "type": "command",
    "command": "python3 pilothOS/scripts/pilothos_guard.py statusline"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py prompt-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py stop-check"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/stop",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py broker-check"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py pre-edit"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read|Bash|Grep|Glob|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh gate /hook/pretool",
            "timeout": 190
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py post-edit"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read|Bash|Grep|Glob|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/posttool",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/notify",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
