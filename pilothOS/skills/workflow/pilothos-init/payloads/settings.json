{
  "permissions": {
    "allow": [
      "Bash(python3 pilothOS/scripts/pilothos_guard.py:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(*secret*)"
    ]
  },
  "env": {
    "PILOTHOS_VERSION": "1.9.0"
  },
  "statusLine": {
    "type": "command",
    "command": "python3 pilothOS/scripts/pilothos_guard.py statusline"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py prompt-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py stop-check"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py pre-edit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 pilothOS/scripts/pilothos_guard.py post-edit"
          }
        ]
      }
    ]
  }
}
