{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read|Bash|Grep|Glob|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh gate /hook/pretool",
            "timeout": 190
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Read|Bash|Grep|Glob|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/posttool",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/notify",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh pilothOS/tools/review/hooks/review-hook.sh fire /hook/stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
